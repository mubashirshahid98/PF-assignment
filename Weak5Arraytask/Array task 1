import java.util.ArrayList;

public class arraytask1 {

    public static void main(String[] args) {

        ArrayList<Integer> values = new ArrayList<>();

        values.add(5);
        values.add(-3);
        values.add(8);
        values.add(-1);
        values.add(12);
        values.add(-7);
        values.add(4);

        // using for-each loop instead of index loop
        for (int num : values) {
            if (num > 0) {
                System.out.println(num);
            }
        }
    }
}
